# Copy this file to deploy.env and fill in real values.
# deploy.env is gitignored -- it never gets committed, same rule as
# SMTP_PASSWORD/TELEGRAM_BOT_TOKEN: real secrets live only in local files
# or the hosting panel's env vars, never in tracked source.

# SSH/SFTP host for tex-biz.ru (ISPmanager) -- the same host you'd put
# into an SFTP client like FileZilla/WinSCP.
DEPLOY_HOST=

# SSH/SFTP port. ISPmanager commonly uses 22, but reg.ru sometimes assigns
# a non-standard port for shared hosting -- check your hosting control panel.
DEPLOY_PORT=22

# SFTP/SSH username for the hosting account.
DEPLOY_USER=

# Absolute path to a private SSH key registered with the hosting account
# (recommended -- no password ever touches this script or your shell
# history). Leave empty to fall back to interactive password prompt.
DEPLOY_SSH_KEY=

# Remote path where the site lives -- the domain's document root.
DEPLOY_REMOTE_PATH=/var/www/USER/data/www/tex-biz.ru
